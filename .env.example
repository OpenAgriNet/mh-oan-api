ENVIRONMENT=development

# Logfire
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=development

# Bhashini API Key
MEITY_API_KEY_VALUE=

# Marqo
MARQO_ENDPOINT_URL=http://localhost:8882/
MARQO_INDEX_NAME=sunbird-va-index

# Redis
REDIS_HOST=redis-stack
REDIS_PORT=6379
REDIS_DB=0

# Mapbox
MAPBOX_API_TOKEN=

# Beckn
BAP_ID=
BAP_URI=
BAP_ENDPOINT=
## BPPs
POCRA_BPP_ID=
POCRA_BPP_URI=
MAHADBT_BPP_ID=
MAHADBT_BPP_URI=

# Azure OpenAI (fallback model)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# vLLM
LLM_PROVIDER=vllm
LLM_AGRINET_MODEL_NAME=agrinet-model
LLM_MODERATION_MODEL_NAME=moderation-model
VLLM_AGRINET_MODEL_URL=http://localhost:8080/v1
VLLM_MODERATION_MODEL_URL=http://localhost:8081/v1

# vLLM Concurrency Limits (optional, defaults shown)
VLLM_AGRINET_MAX_CONCURRENT=60
VLLM_MODERATION_MAX_CONCURRENT=100
